{
  "name": "spikesim",
  "version": "1.2.1",
  "description": "LEGO SPIKE Prime-style robot simulator — blocks + Python, 2D/3D",
  "main": "electron-main.js",
  "bin": "desktop.js",
  "scripts": {
    "start": "node server.js",
    "build:exe": "pkg desktop.js --config package.json --targets node22-win-x64 --output dist/SpikeSim.exe",
    "build:app": "electron-builder --win -p never",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "angads22",
  "license": "ISC",
  "type": "commonjs",
  "pkg": {
    "assets": [
      "index.html",
      "legacy.html",
      "sandbox.html",
      "rover.html",
      "css/**/*",
      "js/**/*",
      "vendor/**/*",
      "challenges/**/*",
      "maps/**/*",
      "models/**/*",
      "examples/**/*"
    ],
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "dist"
  },
  "build": {
    "appId": "com.angads.spikesim",
    "productName": "SpikeSim",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "server.js",
      "index.html",
      "legacy.html",
      "sandbox.html",
      "rover.html",
      "css/**",
      "js/**",
      "vendor/**",
      "challenges/**",
      "maps/**",
      "models/**",
      "examples/**"
    ],
    "asar": true,
    "asarUnpack": [
      "vendor/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "blockly": "^13.1.1",
    "planck": "^1.5.0",
    "pyodide": "^314.0.2",
    "skulpt": "^1.2.0",
    "three": "^0.185.1"
  }
}
